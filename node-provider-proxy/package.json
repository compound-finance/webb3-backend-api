{
  "name": "node-provider-proxy",
  "type": "module",
  "version": "0.0.0",
  "license": "GPL-3.0",
  "private": true,
  "workspaces": [
    "../c3-api/lib/fallible",
    "../c3-api/lib/json-rpc",
    "../c3-api/lib/well-known/networks",
    "../c3-api/lib/well-known/node-providers",
    "../c3-api/tests/util/mock"
  ],
  "engines": {
    "node": ">=19.4.0"
  },
  "dependencies": {
    "@compound-finance/well-known-networks": "1.0.0-alpha.1",
    "@compound-finance/well-known-node-providers": "1.0.0-alpha.3",
    "@ethersproject/abi": "5.6",
    "fallible": "1.0.0-alpha.1",
    "json-rpc": "1.0.0-alpha.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240314.0",
    "@miniflare/kv": "^2.14.2",
    "@miniflare/shared": "^2.14.2",
    "@miniflare/storage-memory": "^2.14.2",
    "@types/node": "^20.3.1",
    "testutil.mock": "1.0.0-alpha.1",
    "typescript": "^4.9.4",
    "wrangler": "^3.1.1"
  },
  "scripts": {
    "preinstall": "cd .. && npm install-clean --workspaces && npm run build --workspaces && npm test --workspaces",
    "start": "wrangler dev --local",
    "test": "node --enable-source-maps --test",
    "clean": "rm -rf dist",
    "build": "tsc",
    "postbuild": "corepack npm test",
    "deploy:production-v2": "wrangler deploy src/index.ts --env production-v2",
    "deploy:production-v3-app": "wrangler deploy src/index.ts --env production-v3-app",
    "deploy:production-v3-api": "wrangler deploy src/index.ts --env production-v3-api"
  }
}
