{
  "name": "webb3-backend-api",
  "type": "module",
  "version": "0.0.0",
  "license": "GPL-3.0",
  "private": true,
  "engines": {
    "node": ">=19.4.0"
  },
  "dependencies": {
    "@compound-finance/sleuth": "^1.0.1-alpha4",
    "@ethersproject/abi": "5.6",
    "js-sha3": "0.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240314.0",
    "@ethersproject/hash": "5.6",
    "@miniflare/kv": "^2.14.1",
    "@miniflare/storage-memory": "^2.14.1",
    "@types/node": "^18.0.6",
    "@types/tap": "^15.0.7",
    "tap": "^16.3.0",
    "typescript": "^4.9.4",
    "wrangler": "^3.7.0"
  },
  "tap": {
    "node-arg": [
      "--no-warnings"
    ]
  },
  "config": {
    "local": "localhost:8787"
  },
  "scripts": {
    "preinstall": "cd .. && npm install-clean --workspaces && npm run build --workspaces && npm test --workspaces",
    "pretest": "tsc",
    "test": "npm run test:tap",
    "test:tap": "npx tap --no-coverage --timeout=900 --test-regex='dist/tests/.*\\.test\\.js'",
    "build": "npx tsc",
    "start": "wrangler dev --local entrypoint.ts",
    "deploy:stage": "npx wrangler publish --env stage",
    "deploy:production": "npx wrangler publish --env production"
  }
}
